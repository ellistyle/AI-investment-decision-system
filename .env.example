# 运行环境：development（Mac开发）| production（Ubuntu生产）
NODE_ENV=development

# 服务端口
PORT=3000

# 阿里百炼 qwen3.5-plus
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# OpenClaw 微信推送（生产环境使用，开发环境走Mock）
OPENCLAW_URL=http://localhost:8080/send
OPENCLAW_TOKEN=your-openclaw-token
OPENCLAW_TARGET=filehelper

# Python 可执行路径
PYTHON_BIN=python3

# 数据库文件路径（留空则自动使用 ~/.investment-system/data.db）
DB_PATH=

# AI 并发上限（个股分析）
AI_CONCURRENCY=5

# 定时任务（生产环境启用；开发环境由 ENABLE_SCHEDULER 控制）
ENABLE_SCHEDULER=false
CRON_MORNING=0 9 * * 1-5
CRON_AFTER_CLOSE=30 15 * * 1-5
CRON_RISK_CHECK=*/5 9-15 * * 1-5

# 日志等级
LOG_LEVEL=info
